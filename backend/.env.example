# MongoDB Connection String

# Вариант 1: Локальная MongoDB
# MONGODB_URI=mongodb://localhost:27017/realtime-messenger

# Вариант 2: MongoDB Atlas (облачная БД) - РЕКОМЕНДУЕТСЯ
# Замените username, password и cluster на ваши данные из MongoDB Atlas
# Если в пароле есть специальные символы (@, #, $, %), закодируйте их:
# @ → %40, # → %23, $ → %24, % → %25
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/realtime-messenger?retryWrites=true&w=majority

# JWT Secret
# ОБЯЗАТЕЛЬНО измените на достаточно длинную случайную строку.
# В продакшене не храните секреты в репозитории, используйте переменные окружения.
JWT_SECRET=dev-secret-change-me-in-production

# Server Port
PORT=4000

# Yandex Maps API key (для фронта — тот же ключ в VITE_YANDEX_MAP_API_KEY)
# Получить: https://developer.tech.yandex.ru/
# YANDEX_MAP_API_KEY=

# CORS origins
# Список разрешённых origin'ов через запятую.
# Для production укажите ваши домены web и api.
# Пример: https://sektor.moscow,https://www.sektor.moscow,https://api.sektor.moscow,http://localhost:19006
CORS_ORIGIN=https://sektor.moscow,https://www.sektor.moscow,https://api.sektor.moscow,http://localhost:19006

# Telegram Bot
# Токен бота Telegram (НЕ коммитить в репозиторий, заполнять только в .env на сервере/локально)
# Пример: TELEGRAM_BOT_TOKEN=1234567890:AA...your-token...
TELEGRAM_BOT_TOKEN=

# URL Telegram WebApp (мини-приложения), который откроется по кнопке в боте
# Например, если мини-приложение доступно по адресу https://sektor.moscow/tg
TELEGRAM_WEBAPP_URL=

# YandexGPT (опционально; если не заданы, фичи с GPT отключены)
# Каталог: https://console.cloud.yandex.ru/ → выберите каталог → ID в URL или настройках
# YANDEX_FOLDER_ID=
# Вариант 1: OAuth-токен (для разработки, токен имеет срок жизни)
# YANDEX_OAUTH_TOKEN=
# Вариант 2: IAM-токен напрямую (обновлять вручную раз в ~12 ч)
# YANDEX_IAM_TOKEN=
# Вариант 3 (рекомендуется): ключ сервисного аккаунта — IAM получается автоматически
# Путь к JSON-файлу (скачанный «Авторизованный ключ» в консоли облака):
# YANDEX_SERVICE_ACCOUNT_KEY_FILE=/path/to/authorized_key.json
# Либо весь JSON ключа в одной строке (для деплоя без файла):
# YANDEX_SERVICE_ACCOUNT_KEY={"id":"...","service_account_id":"...","private_key":"...","public_key":"..."}
# Отключить: YANDEX_GPT_ENABLED=false
