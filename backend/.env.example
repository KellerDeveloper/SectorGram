# MongoDB Connection String

# Вариант 1: Локальная MongoDB
# MONGODB_URI=mongodb://localhost:27017/realtime-messenger

# Вариант 2: MongoDB Atlas (облачная БД) - РЕКОМЕНДУЕТСЯ
# Замените username, password и cluster на ваши данные из MongoDB Atlas
# Если в пароле есть специальные символы (@, #, $, %), закодируйте их:
# @ → %40, # → %23, $ → %24, % → %25
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/realtime-messenger?retryWrites=true&w=majority

# JWT Secret
# ОБЯЗАТЕЛЬНО измените на достаточно длинную случайную строку.
# В продакшене не храните секреты в репозитории, используйте переменные окружения.
JWT_SECRET=dev-secret-change-me-in-production

# Server Port
PORT=4000

# CORS origins
# Список разрешённых origin'ов через запятую.
# Пример: http://localhost:19006,http://localhost:3000,https://myapp.com
CORS_ORIGIN=http://localhost:19006
