# Локальная разработка: не задавайте VITE_API_URL — используется прокси на localhost:4000.
#
# Продакшен на sektor.moscow:
#   API на поддомене: VITE_API_URL=https://api.sektor.moscow
#   API на том же домене (например /api): не задавайте VITE_API_URL или оставьте пустым.
# VITE_API_URL=https://api.sektor.moscow
#
# Ключ Яндекс.Карт (тот же, что в backend .env: YANDEX_MAP_API_KEY)
# Получить: https://developer.tech.yandex.ru/
# VITE_YANDEX_MAP_API_KEY=
