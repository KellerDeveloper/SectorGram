# Адрес backend для реального устройства (iPhone/Android).
# На телефоне localhost указывает на сам телефон, поэтому укажите IP вашего Mac/ПК.
# Узнать IP на Mac: ipconfig getifaddr en0
# iPhone и компьютер должны быть в одной Wi‑Fi сети.

EXPO_PUBLIC_API_BASE_URL=http://192.168.1.XXX:4000
# EXPO_PUBLIC_WS_BASE_URL=http://192.168.1.XXX:4000
